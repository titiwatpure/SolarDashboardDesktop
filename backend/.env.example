PORT=5000
NODE_ENV=development

# JWT - เปลี่ยนเป็นค่าที่ปลอดภัย!
JWT_SECRET=your_secret_key_here_change_this
JWT_EXPIRATION=7d

# Access Token (สั้น)
ACCESS_TOKEN_EXPIRY=15m

# Refresh Token (ยาว)
REFRESH_TOKEN_EXPIRY_DAYS=30

# CORS - URL ของ frontend
CORS_ORIGIN=http://localhost:3000

# Database Path (ใช้สำหรับ Render.com ที่มี Persistent Disk)
# DB_PATH=/var/data/solar_dashboard.db
