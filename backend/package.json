{
  "name": "solar-dashboard-backend",
  "version": "1.1.0",
  "description": "Backend API สำหรับระบบติดตามโครงการ Solar",
  "main": "src/index.js",
  "scripts": {
    "start": "node src/index.js",
    "dev": "nodemon src/index.js",
    "lint": "eslint src/**/*.js",
    "test": "cross-env DB_PATH=./solar_dashboard_test.db NODE_ENV=test jest --runInBand --forceExit --detectOpenHandles",
    "test:watch": "cross-env DB_PATH=./solar_dashboard_test.db NODE_ENV=test jest --watch --runInBand",
    "db:migrate": "node -e \"const db = require('./src/database'); const { runMigrations } = require('./src/migrations/runner'); runMigrations(db.pool).then(() => process.exit(0)).catch(e => { console.error(e); process.exit(1); });\""
  },
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "body-parser": "^1.20.2",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "express-rate-limit": "^8.4.1",
    "helmet": "^8.1.0",
    "jsonwebtoken": "^9.0.2",
    "multer": "^2.1.1",
    "sqlite3": "^6.0.1",
    "uuid": "^9.0.0"
  },
  "devDependencies": {
    "cross-env": "^10.1.0",
    "eslint": "^10.2.1",
    "jest": "^30.3.0",
    "nodemon": "^3.0.1",
    "supertest": "^7.2.2"
  },
  "keywords": [
    "solar",
    "dashboard",
    "tracking"
  ],
  "author": "",
  "license": "MIT",
  "jest": {
    "globalSetup": "./jest.setup.js"
  }
}
