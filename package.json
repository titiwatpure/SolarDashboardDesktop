{
  "name": "solar-dashboard",
  "version": "1.0.18",
  "description": "Solar Dashboard - ระบบติดตามโครงการ Solar (Desktop App)",
  "main": "electron/main.js",
  "scripts": {
    "start": "electron .",
    "dev": "set ELECTRON_DEV=1 && electron .",
    "build:frontend": "cd frontend && npm run build",
