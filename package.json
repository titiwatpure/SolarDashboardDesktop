{
  "name": "solar-dashboard",
  "version": "1.1.0",
  "description": "Solar Dashboard - ระบบติดตามโครงการ Solar (Desktop App)",
  "main": "electron/main.js",
  "scripts": {
    "start": "electron .",
    "dev": "concurrently --names backend,frontend,electron --kill-others \"cd backend && node src/index.js\" \"cd frontend && npm run dev -- --host 127.0.0.1 --port 3000\" \"wait-on http://127.0.0.1:3000 && cross-env ELECTRON_DEV=1 electron .\"",
    "dev:backend": "cd backend && node src/index.js",
    "dev:frontend": "cd frontend && npm run dev -- --host 127.0.0.1 --port 3000",
    "dev:electron": "cross-env ELECTRON_DEV=1 electron .",
    "build:frontend": "cd frontend && npm run build",
    "build:win": "npm run build:frontend && electron-builder --win --config electron-builder.yml",
    "postinstall": "electron-builder install-app-deps"
  },
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "body-parser": "^1.20.2",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "electron-updater": "^6.8.3",
    "express": "^4.18.2",
    "express-rate-limit": "^8.4.1",
    "helmet": "^8.1.0",
    "jsonwebtoken": "^9.0.2",
    "multer": "^2.1.1",
    "sql.js": "^1.14.1",
    "uuid": "^14.0.0"
  },
  "devDependencies": {
    "@electron/rebuild": "^4.0.4",
    "concurrently": "^10.0.3",
    "cross-env": "^10.1.0",
    "electron": "^42.4.0",
    "electron-builder": "^26.15.3",
    "wait-on": "^9.0.10"
  },
  "author": "",
  "license": "MIT"
}
